# Base URL for real backend integration.
# Example: https://api.uix.com
VITE_API_BASE_URL=

# Optional dedicated URL for reminder emails.
# If empty, reminder email uses VITE_API_BASE_URL.
VITE_REMINDER_API_BASE_URL=

# Backend reminder provider options (configured on api-server):
# - Preferred (no domain needed): BREVO_API_KEY + REMINDER_FROM_EMAIL
# - Alternative: SMTP_USER + SMTP_APP_PASSWORD
# - Alternative: RESEND_API_KEY + REMINDER_FROM_EMAIL

# Access code for the Capital Humano panel.
# If omitted, the app uses the default demo code: uix-capital-humano
VITE_CAPITAL_HUMANO_ACCESS_CODE=
