# Required by the current API server bootstrap
PORT=3000
AI_INTEGRATIONS_OPENAI_BASE_URL=http://127.0.0.1:9999
AI_INTEGRATIONS_OPENAI_API_KEY=dummy

# Reminder sender options
# Option A (free, no paid provider): Google Apps Script Webhook
GOOGLE_APPS_SCRIPT_WEBHOOK_URL=
# Optional shared token to protect webhook requests
GOOGLE_APPS_SCRIPT_WEBHOOK_TOKEN=

# Option B: Brevo API with verified sender email
BREVO_API_KEY=
REMINDER_FROM_EMAIL=Talento UiX <talento.uix@gmail.com>

# Option C: Gmail SMTP (requires 2-step verification + App Password)
SMTP_USER=talento.uix@gmail.com
SMTP_APP_PASSWORD=

# Option D (alternative): Resend
# RESEND_API_KEY=
# REMINDER_FROM_EMAIL=Capital Humano <onboarding@resend.dev>
